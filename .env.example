# Locus PayWithLocus API key (claw_...)
LOCUS_API_KEY=

# BuildWithLocus JWT token (exchange via POST /v1/auth/exchange)
LOCUS_BUILD_JWT=

# Locus wallet address (auto-derived from API key)
LOCUS_WALLET_ADDRESS=

# How often to produce a video (cron format, default: every 6h)
SCHEDULE_CRON=0 */6 * * *

# Locus Checkout price per video (USDC)
VIDEO_PRICE_USDC=1.00

# X/Twitter posting (optional - via Locus Wrapped API, no separate key needed)
POST_TO_TWITTER=true

