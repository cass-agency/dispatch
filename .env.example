# ══ Main orchestrator (treasury) ══
# Backs the Dispatch treasury wallet. Receives commissions, pays agents,
# and falls back for any agent without its own key.
LOCUS_API_KEY=claw_...

# ══ Per-agent autonomy keys (optional — each makes that agent self-funding) ══
# If set, the agent's wrapped-API calls debit ITS wallet instead of the main one.
# Unset agents fall back to orchestrator-billed mode (still works).
LOCUS_API_KEY_RESEARCHER=
LOCUS_API_KEY_SCRIPTWRITER=
LOCUS_API_KEY_VISUAL=
LOCUS_API_KEY_VOICE=
LOCUS_API_KEY_MUSIC=

# ══ BuildWithLocus service metadata (from the deploy dashboard) ══
LOCUS_SERVICE_ID=
LOCUS_SERVICE_URL=
LOCUS_ENVIRONMENT_ID=
LOCUS_PROJECT_ID=

PORT=8080
NODE_ENV=development
DEMO_MODE=false
